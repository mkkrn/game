<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>馬ジャンプゲーム</title>

<style>
body {
    margin: 0;
    overflow: hidden;
    background: linear-gradient(#87CEEB, #e0f7ff);
    font-family: sans-serif;
}

#game {
    position: relative;
    width: 100vw;
    height: 300px;
    border-bottom: 5px solid #654321;
}

#horse {
    position: absolute;
    bottom: 0;
    left: 50px;
    width: 60px;
    height: 60px;
    background: brown;
    border-radius: 10px;
}

#obstacle {
    position: absolute;
    bottom: 0;
    right: -40px;
    width: 40px;
    height: 60px;
    background: green;
}

#score {
    position: absolute;
    top: 10px;
    left: 10px;
    font-size: 20px;
}

#gameOver {
    position: absolute;
    top: 100px;
    width: 100%;
    text-align: center;
    font-size: 30px;
    color: red;
    display: none;
}
</style>
</head>

<body>

<div id="game">
    <div id="horse"></div>
    <div id="obstacle"></div>
    <div id="score">スコア: 0</div>
    <div id="gameOver">ゲームオーバー！<br>スペースでリスタート</div>
</div>

<script>
const horse = document.getElementById("horse");
const obstacle = document.getElementById("obstacle");
const scoreDisplay = document.getElementById("score");
const gameOverText = document.getElementById("gameOver");

let jumping = false;
let velocity = 0;
let gravity = 0.6;
let score = 0;
let gameOver = false;
let obstacleX = window.innerWidth;

function jump() {
    if (!jumping) {
        jumping = true;
        velocity = 12;
    }
}

function resetGame() {
    score = 0;
    obstacleX = window.innerWidth;
    gameOver = false;
    gameOverText.style.display = "none";
}

document.addEventListener("keydown", function(e) {
    if (e.code === "Space") {
        if (gameOver) {
            resetGame();
        } else {
            jump();
        }
    }
});

function update() {
    if (gameOver) return;

    // ジャンプ処理
    if (jumping) {
        velocity -= gravity;
        let bottom = parseFloat(horse.style.bottom || 0);
        bottom += velocity;

        if (bottom <= 0) {
            bottom = 0;
            jumping = false;
        }

        horse.style.bottom = bottom + "px";
    }

    // 障害物移動
    obstacleX -= 5;
    obstacle.style.left = obstacleX + "px";

    if (obstacleX < -40) {
        obstacleX = window.innerWidth;
        score++;
    }

    // 当たり判定
    const horseRect = horse.getBoundingClientRect();
    const obstacleRect = obstacle.getBoundingClientRect();

    if (
        horseRect.right > obstacleRect.left &&
        horseRect.left < obstacleRect.right &&
        horseRect.bottom > obstacleRect.top
    ) {
        gameOver = true;
        gameOverText.style.display = "block";
    }

    scoreDisplay.textContent = "スコア: " + score;

    requestAnimationFrame(update);
}

update();
</script>

</body>
</html>
